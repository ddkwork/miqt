prefix=/usr
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include
libsuffix=-3_1

Name: PyImath
Description: Python bindings for the Imath libraries
Version: 3.1.12
Libs: -L${libdir} -lImath${libsuffix} -lPyImath_Python3_12${libsuffix}
Cflags: -I${includedir} -I${includedir}/Imath

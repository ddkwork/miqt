prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib

Name: gcr-4
Description: GObject and GUI library for high level crypto parsing and display
Version: 4.3.0
Requires: glib-2.0 >= 2.68, gio-2.0 >= 2.68, gobject-2.0 >= 2.68, p11-kit-1 >=  0.19.0, gck-2
Libs: -L${libdir} -lgcr-4
Cflags: -I${includedir}/gcr-4

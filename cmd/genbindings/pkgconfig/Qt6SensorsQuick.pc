prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 SensorsQuick
Description: Qt SensorsQuick module
Version: 6.8.1
Libs: -L${libdir} -lQt6SensorsQuick
Cflags: -I${includedir}/QtSensorsQuick -I${includedir} -DQT_SENSORSQUICK_LIB
Requires: Qt6Core Qt6Qml Qt6Sensors

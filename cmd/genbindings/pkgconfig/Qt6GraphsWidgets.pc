prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 GraphsWidgets
Description: Qt GraphsWidgets module
Version: 6.8.1
Libs: -L${libdir} -lQt6GraphsWidgets
Cflags: -I${includedir}/QtGraphsWidgets -I${includedir} -DQT_GRAPHSWIDGETS_LIB
Requires: Qt6Graphs Qt6QuickWidgets

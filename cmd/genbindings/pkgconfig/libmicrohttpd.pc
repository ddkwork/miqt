prefix=/usr
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libmicrohttpd
Description: A library for creating an embedded HTTP server
Version: 1.0.1
Requires:
Requires.private: gnutls
Conflicts:
Libs: -L${libdir} -lmicrohttpd
Libs.private: -lpthread 
Cflags: -I${includedir}

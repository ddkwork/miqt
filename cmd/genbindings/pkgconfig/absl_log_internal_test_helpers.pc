prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: absl_log_internal_test_helpers
Description: Abseil log_internal_test_helpers library
URL: https://abseil.io/
Version: 20240722
Requires: absl_config = 20240722, absl_log_globals = 20240722, absl_log_initialize = 20240722, absl_log_internal_globals = 20240722, absl_log_severity = 20240722
Libs: -L${libdir}  -labsl_log_internal_test_helpers 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX

prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 Positioning
Description: Qt Positioning module
Version: 6.8.1
Libs: -L${libdir} -lQt6Positioning
Cflags: -I${includedir}/QtPositioning -I${includedir} -DQT_POSITIONING_LIB
Requires: Qt6Core

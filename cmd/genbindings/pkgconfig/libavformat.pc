prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: libavformat
Description: FFmpeg container format library
Version: 61.7.100
Requires: 
Requires.private: libavcodec >= 61.19.100, libswresample >= 5.3.100, libavutil >= 59.39.100
Conflicts:
Libs: -L${libdir}  -lavformat 
Libs.private: -lm -latomic -ldvdnav -lpthread -ldvdread -lxml2 -lbz2 -lmodplug -lopenmpt -lstdc++ -lbluray -lgmp -lz -lgnutls -lsrt -lssh -lzmq
Cflags: -I${includedir}

prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 PositioningQuick
Description: Qt PositioningQuick module
Version: 6.8.1
Libs: -L${libdir} -lQt6PositioningQuick
Cflags: -I${includedir}/QtPositioningQuick -I${includedir} -DQT_POSITIONINGQUICK_LIB
Requires: Qt6Core Qt6Positioning Qt6Qml Qt6Quick

prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: absl_crc_cpu_detect
Description: Abseil crc_cpu_detect library
URL: https://abseil.io/
Version: 20240722
Requires: absl_base = 20240722, absl_config = 20240722
Libs: -L${libdir}  -labsl_crc_cpu_detect 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX

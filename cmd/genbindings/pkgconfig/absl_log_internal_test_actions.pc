prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: absl_log_internal_test_actions
Description: Abseil log_internal_test_actions library
URL: https://abseil.io/
Version: 20240722
Requires: absl_config = 20240722, absl_core_headers = 20240722, absl_log_entry = 20240722, absl_log_severity = 20240722, absl_strings = 20240722, absl_time = 20240722
Libs: -L${libdir}  -labsl_log_internal_test_actions 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX

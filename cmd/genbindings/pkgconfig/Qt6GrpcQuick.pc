prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 GrpcQuick
Description: Qt GrpcQuick module
Version: 6.8.1
Libs: -L${libdir} -lQt6GrpcQuick
Cflags: -I${includedir}/QtGrpcQuick -I${includedir} -DQT_GRPCQUICK_LIB
Requires: Qt6Quick

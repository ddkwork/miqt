prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib

exec_prefix=${prefix}

Name: libsoup
Description: A glib-based HTTP library
Version: 2.74.3
Requires: glib-2.0 >=  2.58, gmodule-2.0 >=  2.58, gobject-2.0 >=  2.58, gio-2.0 >=  2.58
Requires.private: sysprof-capture-4, libxml-2.0, sqlite3, libpsl >=  0.20, libbrotlidec, zlib
Libs: -L${libdir} -lsoup-2.4
Libs.private: -lgssapi_krb5 -lkrb5 -lk5crypto -lcom_err
Cflags: -I${includedir}/libsoup-2.4

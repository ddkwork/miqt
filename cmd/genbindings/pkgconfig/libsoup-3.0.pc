prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib

exec_prefix=${prefix}

Name: libsoup
Description: A glib-based HTTP library
Version: 3.6.1
Requires: glib-2.0 >=  2.70.0, gmodule-no-export-2.0 >=  2.70.0, gobject-2.0 >=  2.70.0, gio-2.0 >=  2.70.0
Requires.private: sysprof-capture-4, sqlite3, libpsl >=  0.20, libbrotlidec, zlib, libnghttp2
Libs: -L${libdir} -lsoup-3.0
Libs.private: -lgssapi_krb5 -lkrb5 -lk5crypto -lcom_err
Cflags: -I${includedir}/libsoup-3.0

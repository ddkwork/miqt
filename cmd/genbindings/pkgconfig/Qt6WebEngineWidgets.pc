prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 WebEngineWidgets
Description: Qt WebEngineWidgets module
Version: 6.8.1
Libs: -L${libdir} -lQt6WebEngineWidgets
Cflags: -I${includedir}/QtWebEngineWidgets -I${includedir} -DQT_WEBENGINEWIDGETS_LIB
Requires: Qt6Core Qt6Gui Qt6Widgets Qt6WebEngineCore Qt6PrintSupport

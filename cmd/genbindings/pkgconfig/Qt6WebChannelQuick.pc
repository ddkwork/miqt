prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 WebChannelQuick
Description: Qt WebChannelQuick module
Version: 6.8.1
Libs: -L${libdir} -lQt6WebChannelQuick
Cflags: -I${includedir}/QtWebChannelQuick -I${includedir} -DQT_WEBCHANNELQUICK_LIB

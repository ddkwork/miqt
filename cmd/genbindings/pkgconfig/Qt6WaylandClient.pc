prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 WaylandClient
Description: Qt WaylandClient module
Version: 6.8.1
Libs: -L${libdir} -lQt6WaylandClient
Cflags: -I${includedir}/QtWaylandClient -I${includedir} -DQT_WAYLANDCLIENT_LIB
Requires: Qt6Core Qt6Gui

prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: absl_stack_consumption
Description: Abseil stack_consumption library
URL: https://abseil.io/
Version: 20240722
Requires: absl_config = 20240722, absl_core_headers = 20240722, absl_raw_logging_internal = 20240722
Libs: -L${libdir}  -labsl_stack_consumption 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX

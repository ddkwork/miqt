prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 ProtobufQtGuiTypes
Description: Qt ProtobufQtGuiTypes module
Version: 6.8.1
Libs: -L${libdir} -lQt6ProtobufQtGuiTypes
Cflags: -I${includedir}/QtProtobufQtGuiTypes -I${includedir} -DQT_PROTOBUFQTGUITYPES_LIB
Requires: Qt6ProtobufQtCoreTypes

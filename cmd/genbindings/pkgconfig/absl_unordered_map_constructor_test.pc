prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: absl_unordered_map_constructor_test
Description: Abseil unordered_map_constructor_test library
URL: https://abseil.io/
Version: 20240722
Requires: absl_hash_generator_testing = 20240722, absl_hash_policy_testing = 20240722
Libs: -L${libdir}  
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX -Wno-deprecated-declarations -Wno-missing-declarations -Wno-self-move -Wno-sign-compare -Wno-unused-function -Wno-unused-parameter -Wno-unused-private-field

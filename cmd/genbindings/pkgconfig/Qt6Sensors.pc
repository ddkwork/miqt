prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 Sensors
Description: Qt Sensors module
Version: 6.8.1
Libs: -L${libdir} -lQt6Sensors
Cflags: -I${includedir}/QtSensors -I${includedir} -DQT_SENSORS_LIB
Requires: Qt6Core

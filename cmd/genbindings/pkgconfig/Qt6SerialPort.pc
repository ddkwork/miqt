prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 SerialPort
Description: Qt SerialPort module
Version: 6.8.1
Libs: -L${libdir} -lQt6SerialPort
Cflags: -I${includedir}/QtSerialPort -I${includedir} -DQT_SERIALPORT_LIB
Requires: Qt6Core

prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib

exec_prefix=${prefix}

Name: vte
Description: VTE widget for GTK+ 3.0
Version: 0.78.2
Requires: cairo >= 1.0, gio-2.0 >= 2.72.0, glib-2.0 >= 2.72.0, gobject-2.0, pango >= 1.22.0, gtk+-3.0 >= 3.24.0
Libs: -L${libdir} -lvte-2.91
Cflags: -I${includedir}/vte-2.91

prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib

exec_prefix=${prefix}
datadir=${prefix}/share
interfacesdir=${datadir}/accountsservice/interfaces

Name: Accounts Service
Description: Client Library for communicating with accounts service
Version: 23.13.0
Requires.private: gio-2.0, glib-2.0, gobject-2.0, polkit-gobject-1
Libs: -L${libdir} -laccountsservice
Cflags: -I${includedir}/accountsservice-1.0

prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 Quick3DXr
Description: Qt Quick3DXr module
Version: 6.8.1
Libs: -L${libdir} -lQt6Quick3DXr
Cflags: -I${includedir}/QtQuick3DXr -I${includedir} -DQT_QUICK3DXR_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick Qt6Quick3D

prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 Graphs
Description: Qt Graphs module
Version: 6.8.1
Libs: -L${libdir} -lQt6Graphs
Cflags: -I${includedir}/QtGraphs -I${includedir} -DQT_GRAPHS_LIB
Requires: Qt6Core Qt6Gui Qt6Quick Qt6Quick3D

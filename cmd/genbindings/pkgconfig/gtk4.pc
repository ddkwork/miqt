prefix=/usr
includedir=${prefix}/include
libdir=${prefix}/lib

targets=broadway wayland x11
gtk_binary_version=4.0.0
gtk_host=x86_64-linux

Name: GTK
Description: GTK Graphical UI Library
Version: 4.16.7
Requires: pango >=  1.52.0, pangocairo >=  1.52.0, gdk-pixbuf-2.0 >=  2.30.0, cairo >=  1.18.0, cairo-gobject >=  1.18.0,  vulkan, graphene-gobject-1.0 >=  1.10.0, gio-2.0 >=  2.76.0
Libs: -L${libdir} -lgtk-4
Cflags: -I${includedir}/gtk-4.0

prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 ProtobufQtCoreTypes
Description: Qt ProtobufQtCoreTypes module
Version: 6.8.1
Libs: -L${libdir} -lQt6ProtobufQtCoreTypes
Cflags: -I${includedir}/QtProtobufQtCoreTypes -I${includedir} -DQT_PROTOBUFQTCORETYPES_LIB

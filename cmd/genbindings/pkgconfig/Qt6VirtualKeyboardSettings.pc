prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 VirtualKeyboardSettings
Description: Qt VirtualKeyboardSettings module
Version: 6.8.1
Libs: -L${libdir} -lQt6VirtualKeyboardSettings
Cflags: -I${includedir}/QtVirtualKeyboardSettings -I${includedir} -DQT_VIRTUALKEYBOARDSETTINGS_LIB

prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 WebEngineQuick
Description: Qt WebEngineQuick module
Version: 6.8.1
Libs: -L${libdir} -lQt6WebEngineQuick
Cflags: -I${includedir}/QtWebEngineQuick -I${includedir} -DQT_WEBENGINEQUICK_LIB
Requires: Qt6Core Qt6Gui Qt6Qml Qt6Quick Qt6WebEngineCore Qt6WebChannelQuick

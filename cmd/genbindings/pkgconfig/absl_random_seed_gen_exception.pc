prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: absl_random_seed_gen_exception
Description: Abseil random_seed_gen_exception library
URL: https://abseil.io/
Version: 20240722
Requires: absl_config = 20240722
Libs: -L${libdir}  -labsl_random_seed_gen_exception 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX

prefix=/usr
exec_prefix=${prefix}
libdir=/usr/lib
includedir=/usr/include

Name: absl_random_internal_mock_overload_set
Description: Abseil random_internal_mock_overload_set library
URL: https://abseil.io/
Version: 20240722
Requires: absl_config = 20240722, absl_random_mocking_bit_gen = 20240722, absl_random_internal_mock_helpers = 20240722
Libs: -L${libdir}  
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX

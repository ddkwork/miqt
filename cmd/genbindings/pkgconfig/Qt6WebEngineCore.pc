prefix=/usr
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/bin
libdir=${prefix}/lib
includedir=${prefix}/include

Name: Qt6 WebEngineCore
Description: Qt WebEngineCore module
Version: 6.8.1
Libs: -L${libdir} -lQt6WebEngineCore
Cflags: -I${includedir}/QtWebEngineCore -I${includedir} -DQT_WEBENGINECORE_LIB
Requires: Qt6Core Qt6Gui Qt6Network Qt6Quick Qt6WebChannel Qt6Positioning
